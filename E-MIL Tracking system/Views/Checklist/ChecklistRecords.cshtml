    }

    .checklist-table {
        width: max-content;
        min-width: 2200px;
        border-collapse: collapse;
        table-layout: fixed;
    }

        .checklist-table thead th {
            background: linear-gradient(to bottom, #d9dee8, #c7cfdb);
            color: #111827;
            font-size: 15px;
            font-weight: 700;
            padding: 14px 12px;
            border: 1px solid #7f8aa3;
            text-align: left;
            vertical-align: middle;
            min-width: 130px;
            white-space: normal;
        }

        .checklist-table tbody td {
            background: #0b0f1f;
            color: #F3F4F6;
