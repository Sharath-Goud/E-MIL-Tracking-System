    }

    .table-wrapper::-webkit-scrollbar-thumb {
        background: #64748b;
        border-radius: 10px;
    }

        .table-wrapper::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

    .checklist-table th:first-child,
    .checklist-table td:first-child {
        width: 60px;
        min-width: 60px;
        max-width: 60px;
        text-align: center;
    }

    .checklist-table th:nth-child(5),
