@model List<E_MIL_Tracking_system.DTOs.Checklist.ChecklistResponseDto>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Checklist Records";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="checklist-page">
    <div class="checklist-card">
        <div class="table-section">
            <h3 class="table-title">Checklist Records</h3>
            <div class="table-wrapper">
                <table class="checklist-table" id="checklistTable">
                    <thead>
                        <tr>
                            <th>S.NO</th>
                            <th>Section</th>
                            <th>Station Name</th>
                            <th>Issue Type</th>
                            <th>Problem Statement</th>
                            <th>Frequency</th>
                            <th>Issue Severity</th>
                            <th>Category</th>
                            <th>Starting Date</th>
                            <th>Due Date</th>
                            <th>CM DRI</th>
                            <th>Respective Department</th>
                            <th>Apple DRI</th>
                            <th>Type of Audit</th>
                            <th>Before Image</th>
                            <th>RCCA</th>
                            <th>After Image</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="checklistTableBody">
                        @if (Model != null && Model.Any())
                        {
                            int serialNo = 1;
                            foreach (var item in Model)
                            {
                                <tr class="clickable-row"
                                    onclick="openUpdateModal(
                                        '@item.Id',
                                        '@Html.Raw((item.Rcca ?? "").Replace("'", "\\'"))',
                                        '@item.Status'
                                    )">
                                    <td>@serialNo</td>
                                    <td>@item.Section</td>
                                    <td>@item.StationName</td>
                                    <td>@item.IssueType</td>
                                    <td>@item.ProblemStatement</td>
                                    <td>@item.Frequency</td>
                                    <td>@item.IssueSeverity</td>
                                    <td>@item.Category</td>
                                    <td>@(item.Date?.ToString("dd-MM-yyyy"))</td>
                                    <td>@(item.DueDate?.ToString("dd-MM-yyyy"))</td>
                                    <td>@item.CmDri</td>
                                    <td>@item.RespectiveDepartment</td>
                                    <td>@item.AppleDri</td>
                                    <td>@item.TypeOfAudit</td>

                                    <td onclick="event.stopPropagation();">
                                        @if (!string.IsNullOrWhiteSpace(item.BeforeImagePath))
                                        {
                                            <img src="@item.BeforeImagePath"
                                                 class="table-preview-img clickable-img"
                                                 alt="Before Image"
                                                 onclick="openImageModal(this.src)" />
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>

                                    <td>@(!string.IsNullOrWhiteSpace(item.Rcca) ? item.Rcca : "-")</td>

                                    <td onclick="event.stopPropagation();">
                                        @if (!string.IsNullOrWhiteSpace(item.AfterImagePath))
                                        {
                                            <img src="@item.AfterImagePath"
                                                 class="table-preview-img clickable-img"
                                                 alt="After Image"
                                                 onclick="openImageModal(this.src)" />
                                        }
                                        else
                                        {
                                            var isRccaCompleted = !string.IsNullOrWhiteSpace(item.Rcca);
                                            <div class="after-inline-box @(isRccaCompleted ? "" : "after-disabled-box")">

                                                @if (!isRccaCompleted)
                                                {
                                                    <div class="rcca-lock-message">
                                                        Enter RCCA first
                                                    </div>
                                                }

                                                <form asp-controller="Checklist"
                                                      asp-action="UploadAfterImage"
                                                      method="post"
                                                      enctype="multipart/form-data"
                                                      class="after-inline-form"
                                                      onsubmit="return validateAfterUpload(@item.Id, @isRccaCompleted.ToString().ToLower());">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="Id" value="@item.Id" />

                                                    <div class="custom-upload-box">

                                                        <label for="afterImage_@item.Id"
                                                               class="after-choose-btn @(isRccaCompleted ? "" : "disabled-upload-btn")">
                                                            Choose Image
                                                        </label>

                                                        <span id="fileName_@item.Id" class="selected-file-name">
                                                            No Image Chosen
                                                        </span>

                                                        <input type="file"
                                                               id="afterImage_@item.Id"
                                                               name="AfterImage"
                                                               accept="image/*"
                                                               class="hidden-file-input"
                                                               onchange="updateFileName(this, @item.Id);"
                                                               @(isRccaCompleted ? "" : "disabled") />

                                                        <button type="button"
                                                                class="after-camera-btn"
                                                                onclick="openInlineCamera(@item.Id, @isRccaCompleted.ToString().ToLower())"
                                                                @(isRccaCompleted ? "" : "disabled")>
                                                            <i class="fa fa-camera"></i>
                                                        </button>

                                                        <button type="submit"
                                                                class="after-submit-btn"
                                                                @(isRccaCompleted ? "" : "disabled")>
                                                            Submit
                                                        </button>

                                                    </div>
                                                </form>

                                                <div class="inline-camera-box" id="inlineCameraBox_@item.Id" style="display:none;">
                                                    <video id="inlineVideo_@item.Id" autoplay playsinline></video>
                                                    <canvas id="inlineCanvas_@item.Id" style="display:none;"></canvas>

                                                    <div class="inline-camera-actions">
                                                        <button type="button" class="capture-btn" onclick="captureInlineImage(@item.Id)">Capture</button>
                                                        <button type="button" class="close-btn" onclick="closeInlineCamera(@item.Id)">Close</button>
                                                    </div>
                                                </div>

                                                <form asp-controller="Checklist"
                                                      asp-action="UploadAfterImage"
                                                      method="post"
                                                      enctype="multipart/form-data"
                                                      id="cameraUploadForm_@item.Id"
                                                      style="display:none;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="Id" value="@item.Id" />
                                                    <input type="file" name="AfterImage" id="cameraFileInput_@item.Id" />
                                                </form>
                                            </div>
                                        }
                                    </td>

                                    <td onclick="event.stopPropagation();">
                                        <div class="status-action-box">
                                            <span class="status-badge
                                            @(item.Status == "Ongoing" ? "status-ongoing" :
                                              item.Status == "Closed" ? "status-closed" :
                                              item.Status == "Drop" ? "status-drop" : "status-default")">
                                                @item.Status
                                            </span>

                                            @if (Context.Session.GetString("Role") == "Admin")
                                            {
                                                <button type="button"
                                                        class="status-edit-btn"
                                                        onclick="openStatusModal('@item.Id', '@item.Status')"
                                                        title="Edit Status">
                                                    <i class="fa fa-pen"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                serialNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="17" class="no-data-cell">No checklist records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="imageModal" class="image-modal" onclick="handleModalBackgroundClick(event)">
        <span class="close-modal" onclick="closeImageModal()">&times;</span>
        <img class="modal-content" id="modalImage" alt="Large preview" />
    </div>

    <div id="updateModal" class="custom-modal" onclick="handleUpdateModalBackgroundClick(event)">
        <div class="custom-modal-content">
            <span class="close-update-modal" onclick="closeUpdateModal()">&times;</span>

            <h3 class="update-modal-title">Update Checklist Record</h3>

            <form asp-controller="Checklist"
                  asp-action="UpdateChecklistRecord"
                  method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" id="updateRecordId" name="Id" />

                <div class="form-group">
                    <label for="updateRcca">RCCA</label>
                    <textarea id="updateRcca"
                              name="Rcca"
                              class="update-textarea"
                              placeholder="Enter RCCA"></textarea>
                </div>

                <div class="button-row">
                    <button type="submit" class="save-btn">Submit</button>
                </div>
            </form>
        </div>
    </div>
    <div id="statusModal" class="custom-modal" onclick="handleStatusModalBackgroundClick(event)">
        <div class="custom-modal-content status-modal-content">
            <span class="close-update-modal" onclick="closeStatusModal()">&times;</span>

            <h3 class="update-modal-title">Update Status</h3>

            <form asp-controller="Checklist"
                  asp-action="UpdateStatus"
                  method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" id="statusRecordId" name="Id" />

                <div class="form-group">
                    <label for="updateStatus">Status</label>

                    <select id="updateStatus" name="Status" class="status-select">
                        <option value="Ongoing">Ongoing</option>
                        <option value="Closed">Closed</option>
                        <option value="Drop">Drop</option>
                    </select>
                </div>

                <div class="button-row">
                    <button type="button" class="cancel-status-btn" onclick="closeStatusModal()">Cancel</button>
                    <button type="submit" class="save-btn">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

@if (TempData["SuccessMessage"] != null)
{
    <script>
        window.addEventListener("load", function () {
            showToast("@TempData["SuccessMessage"]", "linear-gradient(to right, #00b09b, #96c93d)");
        });
    </script>
}

@if (TempData["ErrorMessage"] != null)
{
    <script>
        window.addEventListener("load", function () {
            showToast("@TempData["ErrorMessage"]", "linear-gradient(to right, #ff5f6d, #ffc371)");
        });
    </script>
}

<script>
    function showToast(message, bgColor) {
        Toastify({
            text: message,
            duration: 3000,
            gravity: "top",
            position: "right",
            close: true,
            stopOnFocus: true,
            style: {
                background: bgColor,
                borderRadius: "10px",
                padding: "12px 18px"
            }
        }).showToast();
    }

    function openImageModal(src) {
        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("modalImage");

        modalImg.src = src;
        modal.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function closeImageModal() {
        const modal = document.getElementById("imageModal");
        modal.classList.remove("show");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (!modal.classList.contains("show")) {
                document.getElementById("modalImage").src = "";
            }
        }, 650);
    }

    function handleModalBackgroundClick(event) {
        if (event.target.id === "imageModal") {
            closeImageModal();
        }
    }

               function openUpdateModal(id, rcca, status) {
                    const currentStatus = (status || "").trim().toLowerCase();

                    if (currentStatus === "closed" || currentStatus === "close") {
                        return;
                    }

                    document.getElementById("updateRecordId").value = id;
                    document.getElementById("updateRcca").value = rcca || "";
                    document.getElementById("updateModal").classList.add("show");
                    document.body.style.overflow = "hidden";
                }

                function validateAfterUpload(id, isRccaCompleted) {
                    if (!isRccaCompleted) {
                        showToast("Please enter RCCA before uploading After Image.", "linear-gradient(to right, #ff5f6d, #ffc371)");
                        return false;
                    }

                    const fileInput = document.getElementById("afterImage_" + id);

                    if (!fileInput.files || fileInput.files.length === 0) {
                        showToast("Please choose an After Image first.", "linear-gradient(to right, #ff5f6d, #ffc371)");
                        return false;
                    }

                    return true;
                }

                 function openStatusModal(id, status) {
                    document.getElementById("statusRecordId").value = id;
                    document.getElementById("updateStatus").value = status || "Ongoing";
                    document.getElementById("statusModal").classList.add("show");
                    document.body.style.overflow = "hidden";
                }

    function closeStatusModal() {
        document.getElementById("statusModal").classList.remove("show");
        document.body.style.overflow = "";
    }

    function handleStatusModalBackgroundClick(event) {
        if (event.target.id === "statusModal") {
            closeStatusModal();
        }
    }

    function closeUpdateModal() {
        document.getElementById("updateModal").classList.remove("show");
        document.body.style.overflow = "";
    }

    function handleUpdateModalBackgroundClick(event) {
        if (event.target.id === "updateModal") {
            closeUpdateModal();
        }
    }

        document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            closeImageModal();
            closeUpdateModal();
            closeStatusModal();
        }
    });

        function updateFileName(input, id) {
        const fileNameSpan = document.getElementById("fileName_" + id);

        if (input.files.length > 0) {
            fileNameSpan.textContent = input.files[0].name;
        } else {
            fileNameSpan.textContent = "No Image Chosen";
        }
    }
</script>
<script>
    const inlineCameraStreams = {};

        async function openInlineCamera(id, isRccaCompleted) {
        if (!isRccaCompleted) {
            showToast("Please enter RCCA before uploading After Image.", "linear-gradient(to right, #ff5f6d, #ffc371)");
            return;
        }

        const box = document.getElementById("inlineCameraBox_" + id);
        const video = document.getElementById("inlineVideo_" + id);

        try {
            const stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: "environment" },
                audio: false
            });

            inlineCameraStreams[id] = stream;
            video.srcObject = stream;
            box.style.display = "block";
        } catch (error) {
            alert("Unable to access camera. Please allow camera permission.");
            console.error(error);
        }
    }

    function closeInlineCamera(id) {
        const box = document.getElementById("inlineCameraBox_" + id);
        const video = document.getElementById("inlineVideo_" + id);

        if (inlineCameraStreams[id]) {
            inlineCameraStreams[id].getTracks().forEach(track => track.stop());
            inlineCameraStreams[id] = null;
        }

        video.srcObject = null;
        box.style.display = "none";
    }

    function captureInlineImage(id) {
        const video = document.getElementById("inlineVideo_" + id);
        const canvas = document.getElementById("inlineCanvas_" + id);
        const input = document.getElementById("cameraFileInput_" + id);
        const form = document.getElementById("cameraUploadForm_" + id);

        const context = canvas.getContext("2d");
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(function (blob) {
            const file = new File([blob], "after-image-" + id + ".jpg", { type: "image/jpeg" });

            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            input.files = dataTransfer.files;

            closeInlineCamera(id);
            form.submit();
        }, "image/jpeg");
    }
</script>

<style>
    body {
        background: #1D2545;
    }

    .checklist-page {
        padding: 10px 0;
        background: transparent;
        min-height: 100vh;
    }

    .checklist-card {
        background: rgba(255,255,255,0.05);
        border-radius: 24px;
        padding: 24px;
        border: 1px solid rgba(255,255,255,0.14);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.10);
        position: relative;
        overflow: visible;
        transition: all 0.4s ease;
    }

    .table-section {
        margin-top: 0;
    }

    .table-title {
        color: #FFFFFF;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .table-wrapper {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 16px;
