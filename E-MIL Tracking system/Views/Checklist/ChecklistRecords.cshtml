    }

    .close-modal {
        position: absolute;
        top: 80px;
        right: 58px;
        font-size: 25px;
        font-weight: 700;
        color: #ffffff;
        cursor: pointer;
        line-height: 1;
        z-index: 99999;
        display: flex;
