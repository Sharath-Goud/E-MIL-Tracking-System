@model List<E_MIL_Tracking_system.DTOs.Checklist.ChecklistResponseDto>

@{
    ViewData["Title"] = "Report";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="report-page">
    <div class="report-card">
        
        <h3 class="report-title">A2 Reports</h3>
        <form asp-controller="Checklist"
              asp-action="A2Reports"
              method="get"
              class="filter-box">

            <div class="filter-item">
                <label>Month</label>
                <select name="month">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(ViewBag.SelectedMonth == m)">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <label>Year</label>
                <select name="year">
                    @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                    {
                        <option value="@y" selected="@(ViewBag.SelectedYear == y)">
                            @y
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <label>Week</label>
                <select name="week">
                    <option value="0">All Weeks</option>
                    <option value="1"
                            selected="@(ViewBag.SelectedWeek == 1)">
                        Week 1
                    </option>
                    <option value="2"
                            selected="@(ViewBag.SelectedWeek == 2)">
                        Week 2
                    </option>
                    <option value="3"
                            selected="@(ViewBag.SelectedWeek == 3)">
                        Week 3
                    </option>
                    <option value="4"
                            selected="@(ViewBag.SelectedWeek == 4)">
                        Week 4
                    </option>
                    <option value="5"
                            selected="@(ViewBag.SelectedWeek == 5)">
                        Week 5
                    </option>
                </select>
            </div>

            <div class="filter-item">
                <label>Status</label>
                <select name="status">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(ViewBag.SelectedStatus))">All Status</option>
                    <option value="Ongoing" selected="@(ViewBag.SelectedStatus == "Ongoing")">Ongoing</option>
                    <option value="Closed" selected="@(ViewBag.SelectedStatus == "Closed")">Closed</option>
                    <option value="Drop" selected="@(ViewBag.SelectedStatus == "Drop")">Drop</option>
                </select>
            </div>

            <div class="filter-item search-box">
                <label>Search</label>
                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       placeholder="Search here..." />
            </div>

            <div class="filter-buttons">
                <button type="submit" class="apply-filter-btn">Apply Filter</button>

                <a asp-controller="Checklist"
                   asp-action="A2Reports"
                   class="reset-filter-btn">
                    Reset
                </a>
            </div>
        </form>

        <div class="table-wrapper">
            <table class="report-table" id="a2ReportTable">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Week</th>
                        <th>Project</th>
                        <th>Date</th>
                        <th>Problem Statement</th>
                        <th>Picture Before</th>
                        <th>Picture After</th>
                        <th>Frequency</th>
                        <th>DRI</th>
                        <th>C/P</th>
                    </tr>
                </thead>

                <tbody id="a2ReportTableBody">
                    @if (Model != null && Model.Any())
                    {
                        int serialNo = 1;

                        foreach (var item in Model)
                        {
                            <tr class="a2-report-row">
                                <td>@serialNo</td>

                                <td>@item.WeekCode</td>

                                <td>@item.Project</td>

                                <td>@(item.Date?.ToString("d-MMM"))</td>

                                <td>
                                    <strong>Issue : @item.Line : @item.StationName</strong><br />
                                    <strong>Problem Statement :</strong><br />
                                    @item.ProblemStatement
                                    <br /><br />

                                    <strong>Root Cause Corrective Action : </strong><br />
                                    @(!string.IsNullOrWhiteSpace(item.Rcca) ? item.Rcca : "-")
                              
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.BeforeImagePath))
                                    {
                                        <div class="before-images-grid">
                                            @foreach (var img in item.BeforeImagePath.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <img src="@img.Trim()"
                                                     class="table-preview-img clickable-img before-grid-img"
                                                     alt="Before Image"
                                                     onclick="openImageModal(this.src)" />
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.AfterImagePath))
                                    {
                                        <img src="@item.AfterImagePath"
                                             class="table-preview-img clickable-img"
                                             alt="After Image"
                                             onclick="openImageModal(this.src)" />
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>@item.Frequency</td>

                                <td>@item.CmDri</td>

                                <td>@(item.DueDate?.ToString("d-MMM"))</td>
                            </tr>

                            serialNo++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="no-data-cell">
                                No checklist records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="records-pagination" id="recordsPagination"></div>
        <div id="imageModal" class="image-modal" onclick="handleModalBackgroundClick(event)">
            <span class="close-modal" onclick="closeImageModal()">&times;</span>
            <img class="modal-content" id="modalImage" alt="Large preview" />
        </div>
    </div>
</div>
<script>
    function openImageModal(src) {
        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("modalImage");

        modalImg.src = src;
        modal.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function closeImageModal() {
        const modal = document.getElementById("imageModal");
        modal.classList.remove("show");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (!modal.classList.contains("show")) {
                document.getElementById("modalImage").src = "";
            }
        }, 500);
    }

    function handleModalBackgroundClick(event) {
        if (event.target.id === "imageModal") {
            closeImageModal();
        }
    }

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            closeImageModal();
        }
    });

        document.addEventListener("DOMContentLoaded", function () {
        const rowsPerPage = 10;
        const tableBody = document.getElementById("a2ReportTableBody");
        const pagination = document.getElementById("recordsPagination");

        if (!tableBody || !pagination) return;

        const rows = Array.from(tableBody.querySelectorAll("tr.a2-report-row"));
        let currentPage = 1;
        const totalPages = Math.ceil(rows.length / rowsPerPage);

        function showPage() {
            rows.forEach((row, index) => {
                row.style.display =
                    index >= (currentPage - 1) * rowsPerPage &&
                    index < currentPage * rowsPerPage
                        ? ""
                        : "none";

                if (row.style.display !== "none") {
                    row.querySelector("td:first-child").textContent = index + 1;
                }
            });

            buildPagination();
        }

        function buildPagination() {
            pagination.innerHTML = "";
            if (totalPages <= 1) return;

            pagination.appendChild(makeBtn("← Prev", "page-nav-btn", currentPage === 1, function () {
                currentPage--;
                showPage();
            }));

            getPages().forEach(page => {
                if (page === "...") {
                    const dots = document.createElement("span");
                    dots.className = "page-dots";
                    dots.textContent = "...";
                    pagination.appendChild(dots);
                } else {
                    const btn = makeBtn(page, "page-number-btn", false, function () {
                        currentPage = page;
                        showPage();
                    });

                    if (page === currentPage) btn.classList.add("active");
                    pagination.appendChild(btn);
                }
            });

            pagination.appendChild(makeBtn("Next →", "page-nav-btn", currentPage === totalPages, function () {
                currentPage++;
                showPage();
            }));
        }

        function makeBtn(text, className, disabled, clickFn) {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = className;
            btn.textContent = text;
            btn.disabled = disabled;

            btn.onclick = function () {
                if (!disabled) clickFn();
            };

            return btn;
        }

        function getPages() {
            const pages = [];

            if (totalPages <= 7) {
                for (let i = 1; i <= totalPages; i++) pages.push(i);
                return pages;
            }

            pages.push(1);

            if (currentPage > 4) pages.push("...");

            const start = Math.max(2, currentPage - 1);
            const end = Math.min(totalPages - 1, currentPage + 1);

            for (let i = start; i <= end; i++) pages.push(i);

            if (currentPage < totalPages - 3) pages.push("...");

            pages.push(totalPages);

            return pages;
        }

        showPage();
    });
</script>
