    const statusField = document.getElementById("status");
    const checklistForm = document.getElementById("checklistForm");

    if (dateInput) {
        dateInput.addEventListener("change", function () {
            if (!this.value) {
                weekCodeInput.value = "";
                monthInput.value = "";
                updateStatusAutomatically();
                return;
            }

            const selectedDate = new Date(this.value);

            if (isNaN(selectedDate.getTime())) {
                weekCodeInput.value = "";
                monthInput.value = "";
                updateStatusAutomatically();
                return;
            }

            monthInput.value = selectedDate.toLocaleString("en-US", { month: "long" });

            const weekNumber = getISOWeekNumber(selectedDate);
            weekCodeInput.value = "WK-" + String(weekNumber).padStart(2, "0");

            updateStatusAutomatically();
        });
    }

    function getISOWeekNumber(date) {
        const tempDate = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = tempDate.getUTCDay() || 7;

        tempDate.setUTCDate(tempDate.getUTCDate() + 4 - dayNum);

        const yearStart = new Date(Date.UTC(tempDate.getUTCFullYear(), 0, 1));
        return Math.ceil((((tempDate - yearStart) / 86400000) + 1) / 7);
    }

    function startSpeech(fieldId, btnElement) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        if (!SpeechRecognition) {
            alert("Use Chrome browser");
            return;
        }

        if (btnElement) {
            btnElement.classList.add("recording");
        }

        const recognition = new SpeechRecognition();
        recognition.start();

        recognition.onresult = function (event) {
            const text = event.results[0][0].transcript;
            document.getElementById(fieldId).value += " " + text;
            updateStatusAutomatically();
        };

        recognition.onend = function () {
            if (btnElement) {
                btnElement.classList.remove("recording");
            }
        };
    }

        function updateStatusAutomatically() {
        const fields = [
            "date",
            "weekCode",
            "month",
            "project",
            "line",
            "section",
            "stationName",
            "issueType",
            "problemStatement",
            "frequency",
            "issueSeverity",
            "category",
            "dueDate",
            "cmDri",
            "respectiveDepartment",
            "appleDri",
            "typeOfAudit",
            "auditor",
        ];

        let allFilled = true;

        fields.forEach(id => {
            const field = document.getElementById(id);

            if (!field || !field.value || field.value.trim() === "") {
                allFilled = false;
            }
        });

        const beforeImage = document.getElementById("beforeImage");

        if (!beforeImage || beforeImage.files.length === 0) {
            allFilled = false;
        }

        const statusField = document.getElementById("status");

        if (statusField) {
            statusField.value = allFilled ? "Ongoing" : "";
        }
    }

        const issueTypeInput = document.getElementById("issueType");
    const frequencyInput = document.getElementById("frequency");

    function handleFrequencyByIssueType() {
        if (!issueTypeInput || !frequencyInput) return;

        if (issueTypeInput.value === "New") {
            frequencyInput.value = "1";
            frequencyInput.disabled = true;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "none";
                wrapper.style.opacity = "0.7";
            }
        }
        else if (issueTypeInput.value === "Repeated") {
            frequencyInput.value = "";
            frequencyInput.disabled = false;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "auto";
                wrapper.style.opacity = "1";
            }
        }
        else {
            frequencyInput.value = "";
            frequencyInput.disabled = false;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "auto";
                wrapper.style.opacity = "1";
            }
        }

        updateStatusAutomatically();
    }

    if (issueTypeInput) {
        issueTypeInput.addEventListener("change", handleFrequencyByIssueType);
    }

    handleFrequencyByIssueType();

    if (checklistForm) {
        const fieldsToWatch = [
            document.getElementById("date"),
            document.getElementById("weekCode"),
            document.getElementById("month"),
            document.getElementById("project"),
            document.getElementById("line"),
            document.getElementById("section"),
            document.getElementById("stationName"),
            document.getElementById("issueType"),
            document.getElementById("problemStatement"),
            document.getElementById("frequency"),
            document.getElementById("issueSeverity"),
            document.getElementById("category"),
            document.getElementById("dueDate"),
            document.getElementById("cmDri"),
            document.getElementById("respectiveDepartment"),
            document.getElementById("appleDri"),
            document.getElementById("typeOfAudit"),
            document.getElementById("auditor"),
            document.getElementById("beforeImage")
        ];

        fieldsToWatch.forEach(field => {
            if (!field) return;
            field.addEventListener("change", updateStatusAutomatically);
            field.addEventListener("input", updateStatusAutomatically);
        });

        checklistForm.addEventListener("submit", function (e) {
                if (frequencyInput) {
                    frequencyInput.disabled = false;
                }
            const requiredFields = [
                document.getElementById("date"),
                document.getElementById("weekCode"),
                document.getElementById("month"),
                document.getElementById("project"),
                document.getElementById("line"),
                document.getElementById("section"),
                document.getElementById("stationName"),
                document.getElementById("issueType"),
                document.getElementById("problemStatement"),
                document.getElementById("frequency"),
                document.getElementById("issueSeverity"),
                document.getElementById("category"),
                document.getElementById("dueDate"),
                document.getElementById("cmDri"),
                document.getElementById("respectiveDepartment"),
                document.getElementById("appleDri"),
                document.getElementById("typeOfAudit"),
                document.getElementById("beforeImage"),
                document.getElementById("status")
            ];

            let isValid = true;

            requiredFields.forEach(field => {
                if (!field) return;

                if (field.type === "file") {
                    if (field.files.length === 0) {
                        isValid = false;
                    }
                } else {
                    if (!field.value || field.value.trim() === "") {
                        isValid = false;
                    }
                }
            });

            if (!isValid) {
                e.preventDefault();
                showToast("Please provide all the input fields", "linear-gradient(to right, #ff5f6d, #ffc371)");
            }
        });

        updateStatusAutomatically();
    }
</script>
<script>
    let activeDropdownId = "";
    let activeDropdownLabel = "";
    let dropdownActionMode = "";
    let selectedOldValue = "";

    const dynamicDropdownIds = [
        "section",
        "stationName",
        "issueSeverity",
        "category",
        "cmDri",
        "respectiveDepartment",
        "appleDri",
        "auditor"
    ];

        function openDropdownPopup(dropdownId, labelName, mode) {
        activeDropdownId = dropdownId;
        activeDropdownLabel = labelName;
        dropdownActionMode = mode;

        const dropdown = document.getElementById(dropdownId);
        const input = document.getElementById("dropdownNewValue");
        const title = document.getElementById("dropdownPopupTitle");
        const deleteText = document.getElementById("deleteConfirmText");
        const editSelect = document.getElementById("dropdownEditSelect");

        input.value = "";
        input.style.display = "block";
        editSelect.style.display = "none";
        editSelect.innerHTML = `<option value="">Select ${labelName}</option>`;
        deleteText.style.display = "none";
        deleteText.innerText = "";

        if (mode === "add") {
            title.innerText = "Add " + labelName;
            input.placeholder = "Enter " + labelName;
        }

        if (mode === "edit") {
            title.innerText = "Edit " + labelName;
            input.placeholder = "Or enter new " + labelName;

            editSelect.style.display = "block";

            Array.from(dropdown.options).forEach(option => {
                if (option.value && option.value.trim() !== "") {
                    const opt = document.createElement("option");
                    opt.value = option.value;
                    opt.text = option.text;
                    editSelect.appendChild(opt);
                }
            });

            editSelect.onchange = function () {
                input.value = this.value;
                selectedOldValue = this.value;
            };
        }

        if (mode === "delete") {
            if (!dropdown || !dropdown.value) {
                showToast("Please select " + labelName + " to delete", "linear-gradient(to right, #ff5f6d, #ffc371)");
                return;
            }

            selectedOldValue = dropdown.value;
            title.innerText = "Delete " + labelName;
            input.style.display = "none";
            editSelect.style.display = "none";
            deleteText.style.display = "block";
            deleteText.innerText = "Are you sure you want to delete '" + selectedOldValue + "'?";
        }

        document.getElementById("dropdownPopup").classList.add("show");
    }

    function closeDropdownPopup() {
        document.getElementById("dropdownPopup").classList.remove("show");
    }

    function submitDropdownAction() {
        if (dropdownActionMode === "add") {
            addDropdownValue();
        } else if (dropdownActionMode === "edit") {
            updateDropdownValue();
        } else if (dropdownActionMode === "delete") {
            deleteSelectedDropdownValue();
        }
    }

    function addDropdownValue() {
        const input = document.getElementById("dropdownNewValue");
        const newValue = input.value.trim();
        const dropdown = document.getElementById(activeDropdownId);

        if (!newValue) {
            showToast("Please enter " + activeDropdownLabel, "linear-gradient(to right, #ff5f6d, #ffc371)");
            return;
        }

        const exists = Array.from(dropdown.options).some(x =>
            x.value.toLowerCase() === newValue.toLowerCase()
        );

        if (exists) {
            showToast(activeDropdownLabel + " already exists", "linear-gradient(to right, #ff5f6d, #ffc371)");
            return;
        }

        const option = document.createElement("option");
        option.value = newValue;
        option.text = newValue;
        dropdown.appendChild(option);
        dropdown.value = newValue;

        saveDropdownValueToLocalStorage(activeDropdownId, newValue);
        updateStatusAutomatically();
        closeDropdownPopup();

        showToast("Added successfully", "linear-gradient(to right, #00b09b, #96c93d)");
    }

        function updateDropdownValue() {
        const input = document.getElementById("dropdownNewValue");
        const editSelect = document.getElementById("dropdownEditSelect");
        const dropdown = document.getElementById(activeDropdownId);

        const selectedValue = editSelect.value.trim();
        const newValue = input.value.trim();

        if (!selectedValue && !newValue) {
            showToast("Please select or enter " + activeDropdownLabel, "linear-gradient(to right, #ff5f6d, #ffc371)");
            return;
        }

        if (selectedValue && newValue) {
            const selectedOption = Array.from(dropdown.options)
                .find(option => option.value === selectedValue);

            if (selectedOption) {
                selectedOption.value = newValue;
                selectedOption.text = newValue;
            }

            dropdown.value = newValue;
            updateDropdownLocalStorage(activeDropdownId, selectedValue, newValue);
            showToast("Updated successfully", "linear-gradient(to right, #00b09b, #96c93d)");
        }
        else if (!selectedValue && newValue) {
            const exists = Array.from(dropdown.options).some(option =>
                option.value.toLowerCase() === newValue.toLowerCase()
            );

            if (exists) {
                showToast(activeDropdownLabel + " already exists", "linear-gradient(to right, #ff5f6d, #ffc371)");
                return;
            }

            const option = document.createElement("option");
            option.value = newValue;
            option.text = newValue;
            dropdown.appendChild(option);
            dropdown.value = newValue;

            saveDropdownValueToLocalStorage(activeDropdownId, newValue);
            showToast("Added successfully", "linear-gradient(to right, #00b09b, #96c93d)");
        }

        updateStatusAutomatically();
        closeDropdownPopup();
    }

    function deleteSelectedDropdownValue() {
        const dropdown = document.getElementById(activeDropdownId);

        dropdown.remove(dropdown.selectedIndex);
        dropdown.value = "";

        removeDropdownValueFromLocalStorage(activeDropdownId, selectedOldValue);
        updateStatusAutomatically();
        closeDropdownPopup();

        showToast("Deleted successfully", "linear-gradient(to right, #00b09b, #96c93d)");
    }

    function saveDropdownValueToLocalStorage(dropdownId, value) {
        const key = "dynamic_" + dropdownId;
        const values = JSON.parse(localStorage.getItem(key)) || [];

        if (!values.some(x => x.toLowerCase() === value.toLowerCase())) {
            values.push(value);
            localStorage.setItem(key, JSON.stringify(values));
        }
    }

    function updateDropdownLocalStorage(dropdownId, oldValue, newValue) {
        const key = "dynamic_" + dropdownId;
        let values = JSON.parse(localStorage.getItem(key)) || [];

        values = values.map(x =>
            x.toLowerCase() === oldValue.toLowerCase() ? newValue : x
        );

        localStorage.setItem(key, JSON.stringify(values));
    }

    function removeDropdownValueFromLocalStorage(dropdownId, value) {
        const key = "dynamic_" + dropdownId;
        let values = JSON.parse(localStorage.getItem(key)) || [];

        values = values.filter(x =>
            x.toLowerCase() !== value.toLowerCase()
        );

        localStorage.setItem(key, JSON.stringify(values));
    }

    function loadDynamicDropdownValues() {
        dynamicDropdownIds.forEach(dropdownId => {
            const dropdown = document.getElementById(dropdownId);
            if (!dropdown) return;

            const key = "dynamic_" + dropdownId;
            const values = JSON.parse(localStorage.getItem(key)) || [];

            values.forEach(value => {
                const exists = Array.from(dropdown.options).some(option =>
                    option.value.toLowerCase() === value.toLowerCase()
                );

                if (!exists) {
                    const option = document.createElement("option");
                    option.value = value;
                    option.text = value;
                    dropdown.appendChild(option);
                }
            });
        });
    }

    document.addEventListener("DOMContentLoaded", loadDynamicDropdownValues);

    document.getElementById("dropdownNewValue")?.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
            submitDropdownAction();
        }
    });
</script>
<script>
    function openImageModal(src) {
        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("modalImage");

        modalImg.src = src;
        modal.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function closeImageModal() {
        const modal = document.getElementById("imageModal");

        modal.classList.remove("show");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (!modal.classList.contains("show")) {
                document.getElementById("modalImage").src = "";
            }
        }, 650);
    }

    function handleModalBackgroundClick(event) {
        if (event.target.id === "imageModal") {
            closeImageModal();
        }
    }

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            closeImageModal();
        }
    });
</script>
