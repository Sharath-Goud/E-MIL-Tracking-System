        <hr class="form-divider">
        <div class="table-section">
            <div class="table-header-row">
                <h3 class="table-title">Checklist Records</h3>

                @if (isAdmin)
                {
                    <form asp-controller="Checklist"
                          asp-action="SendTodayChecklistMail"
                          method="post"
                          class="table-submit-form">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="save-btn">
                            Submit Today Records
                        </button>
                    </form>
                }
            </div>
            <div class="table-wrapper">
                <table class="checklist-table" id="checklistTable">
                    <thead>
                        <tr>
                            <th>S.NO</th>
                            <th>Section</th>
                            <th>Station Name</th>
                            <th>Issue Type</th>
                            <th>Problem Statement</th>
                            <th>Frequency</th>
                            <th>Issue Severity</th>
                            <th>Category</th>
                            <th>Starting Date</th>
                            <th>Due Date</th>
                            <th>CM DRI</th>
                            <th>Respective Department</th>
                            <th>Apple DRI</th>
                            <th>Type of Audit</th>
                            <th>Auditor</th>
                            <th>Before Image</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="checklistTableBody">
                        @if (Model != null && Model.Any(x => x.Date.HasValue && x.Date.Value.Date == DateTime.Today))
                        {
                            int serialNo = 1;

                            foreach (var item in Model
                            .Where(x => x.Date.HasValue && x.Date.Value.Date == DateTime.Today)
                            .OrderByDescending(x => x.Date))
                            {
                                <tr>
                                    <td>@serialNo</td>
                                    <td>@item.Section</td>
                                    <td>@item.StationName</td>
                                    <td>@item.IssueType</td>
                                    <td>
                                        <span class="problem-text">@item.ProblemStatement</span>
                                    </td>
                                    <td>@item.Frequency</td>
                                    <td>@item.IssueSeverity</td>
                                    <td>@item.Category</td>
                                    <td>@(item.Date?.ToString("dd-MM-yyyy"))</td>
                                    <td>@(item.DueDate?.ToString("dd-MM-yyyy"))</td>
                                    <td>@item.CmDri</td>
                                    <td>@item.RespectiveDepartment</td>
                                    <td>@item.AppleDri</td>
                                    <td>@item.TypeOfAudit</td>
                                    <td>@item.Auditor</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.BeforeImagePath))
                                        {
                                            <img src="@item.BeforeImagePath"
                                                 class="table-preview-img clickable-img"
                                                 alt="Before Image"
                                                 onclick="openImageModal(this.src)" />
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="status-badge
                                        @(item.Status == "Ongoing" ? "status-ongoing" :
                                          item.Status == "Closed" ? "status-closed" :
                                          item.Status == "Drop" ? "status-drop" : "status-default")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>

                                serialNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="17" style="text-align:center;">No records found for today</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div id="imageModal" class="image-modal" onclick="handleModalBackgroundClick(event)">
        <span class="close-modal" onclick="closeImageModal()">&times;</span>
        <img class="modal-content" id="modalImage" alt="Large preview" />
    </div>
    <div id="dropdownPopup" class="dropdown-popup-overlay">
        <div class="dropdown-popup-box">
            <button type="button" class="popup-close-btn" onclick="closeDropdownPopup()">
                &times;
            </button>

            <h3 id="dropdownPopupTitle">Add Value</h3>
            <select id="dropdownEditSelect" style="display:none;" class="popup-edit-select">
                <option value="">Select value</option>
            </select>
            <input type="text" id="dropdownNewValue" placeholder="Enter value" />

            <p id="deleteConfirmText" class="delete-confirm-text" style="display:none;"></p>

            <button type="button" class="popup-submit-btn" onclick="submitDropdownAction()">
                Submit
            </button>
        </div>
    </div>
</div>

<script>
    const cameraStreams = {};

    async function openCamera(type) {
        const cameraBox = document.getElementById(type + "CameraBox");
        const video = document.getElementById(type + "Video");

        try {
            const stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: "environment" },
                audio: false
            });

            cameraStreams[type] = stream;
            video.srcObject = stream;
            cameraBox.style.display = "block";
        } catch (error) {
            alert("Unable to access camera. Please allow camera permission or use Choose File.");
            console.error(error);
        }
    }

        let beforeSelectedFiles = [];

    const beforeImageInput = document.getElementById("beforeImage");

        if (beforeImageInput) {
        beforeImageInput.addEventListener("change", function (e) {
            const files = Array.from(e.target.files);

            files.forEach(file => {
                beforeSelectedFiles.push(file);
            });

            updateMultipleImagePreview();
            e.target.value = "";
        });
    }

    function updateMultipleImagePreview() {
        const previewBox = document.getElementById("beforePreviewBox");
        const text = document.getElementById("beforeFileText");
        const fileInput = document.getElementById("beforeImage");

        previewBox.innerHTML = "";

        if (beforeSelectedFiles.length === 0) {
            text.style.display = "inline";
            previewBox.appendChild(text);
            updateStatusAutomatically();
            return;
        }

        beforeSelectedFiles.forEach((file, index) => {
            const imageUrl = URL.createObjectURL(file);

            const wrapper = document.createElement("div");
            wrapper.className = "inside-preview-item";

            wrapper.innerHTML = `
                <img src="${imageUrl}" onclick="openImageModal('${imageUrl}')" />

                <button type="button"
                        class="inside-preview-remove"
                        onclick="removeMultipleImage(${index})">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            `;

            previewBox.appendChild(wrapper);
        });

        const dataTransfer = new DataTransfer();

        beforeSelectedFiles.forEach(file => {
            dataTransfer.items.add(file);
        });

        fileInput.files = dataTransfer.files;

        updateStatusAutomatically();
    }

    function removeMultipleImage(index) {
        beforeSelectedFiles.splice(index, 1);
        updateMultipleImagePreview();
    }

    function captureImage(type) {
        const video = document.getElementById(type + "Video");
        const canvas = document.getElementById(type + "Canvas");

        const context = canvas.getContext("2d");

        canvas.width = video.videoWidth;
