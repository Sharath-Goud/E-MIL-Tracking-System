@model List<E_MIL_Tracking_system.DTOs.Checklist.ChecklistResponseDto>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
@{
    ViewData["Title"] = "Checklist";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="checklist-page">
    <div class="checklist-card">
        <h2 class="checklist-title">Checklist Form</h2>

        <form id="checklistForm" class="checklist-form" asp-controller="Checklist"
              asp-action="Create"
              method="post"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="date" id="date" name="Date" />
                </div>

                <div class="form-group">
                    <label for="weekCode">Week code</label>
                    <input type="text" id="weekCode" name="WeekCode" placeholder="Week code" readonly />
                </div>

                <div class="form-group">
                    <label for="month">Month</label>
                    <input type="text" id="month" name="Month" placeholder="Month" readonly />
                </div>

                <div class="form-group">
                    <label for="project">Project</label>
                    <div class="select-wrapper">
                        <select id="project" name="Project">
                            <option value="">Select Project</option>
                            <option value="A191">A191</option>
                            <option value="A191M">A191M</option>
                            <option value="A246C">A246C</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="line">Line</label>
                    <div class="select-wrapper">
                        <select id="line" name="Line">
                            <option value="">Select Line</option>
                            <option value="Line-1">Line-1</option>
                            <option value="Line-2">Line-2</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>
            </div>

            <hr class="form-divider">

            <div class="form-section-title">Issue Details</div>

            <div class="form-row form-row-large">
                <div class="form-group">
                    <label for="section">Section</label>
                    <div class="select-wrapper">
                        <select id="section" name="Section">
                            <option value="">Select Section</option>
                            <option value="FATP">FATP</option>
                            <option value="WH">WH</option>
                            <option value="Testing">Testing</option>
                            <option value="Packing">Packing</option>
                            <option value="OBA">OBA</option>
                            <option value="Kitting">Kitting</option>
                            <option value="Lab">Lab</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="stationName">Station Name</label>
                    <div class="select-wrapper">
                        <select id="stationName" name="StationName">
                            <option value="">Select Station</option>
                            <option value="Station-1">Station-1</option>
                            <option value="Station-2">Station-2</option>
                            <option value="Station-3">Station-3</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="issueType">Issue Type</label>
                    <div class="select-wrapper">
                        <select id="issueType" name="IssueType">
                            <option value="">Select Issue Type</option>
                            <option value="New">New</option>
                            <option value="Repeated">Repeated</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="problemStatement">Problem Statement</label>

                    <div class="textarea-wrapper">
                        <textarea id="problemStatement"
                                  name="ProblemStatement"
                                  placeholder="Enter problem statement"></textarea>

                        <button type="button" class="mic-btn" onclick="startSpeech('problemStatement', this)">
                            <i class="fa-solid fa-microphone"></i>
                        </button>
                    </div>
                </div>


                <div class="form-group">
                    <label for="frequency">Frequency</label>
                    <div class="select-wrapper">
                        <select id="frequency" name="Frequency">
                            <option value="">Select Frequency</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                            <option value="7">7</option>
                            <option value="8">8</option>
                            <option value="9">9</option>
                            <option value="10">10</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="issueSeverity">Issue Severity</label>
                    <div class="select-wrapper">
                        <select id="issueSeverity" name="IssueSeverity">
                            <option value="">Select Severity</option>
                            <option value="Major">Major</option>
                            <option value="Minor">Minor</option>
                            <option value="Critical">Critical</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="category">Category</label>
                    <div class="select-wrapper">
                        <select id="category" name="Category">
                            <option value="">Select Category</option>
                            <option value="5S/ESD">5S/ESD</option>
                            <option value="SIP/SOP">SIP/SOP</option>
                            <option value="Violation">Violation</option>
                            <option value="CTQ Out-Off Spec">CTQ Out-Off Spec</option>
                            <option value="Maintenance/Callibrition/Setting">Maintenance/Callibrition/Setting</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="dueDate">Due Date</label>
                    <input type="date" id="dueDate" name="DueDate" />
                </div>

                <div class="form-group">
                    <label for="cmDri">CM DRI</label>
                    <div class="select-wrapper">
                        <select id="cmDri" name="CmDri">
                            <option value="">Select CM DRI</option>
                            <option value="Rakesh (Prod)">Rakesh (Prod)</option>
                            <option value="Thanuja (QC)">Thanuja (QC)</option>
                            <option value="Jeevan (Main)">Jeevan (Main)</option>
                            <option value="Aravind (PIE)">Aravind (PIE)</option>
                            <option value="Sai balaji (Testing)">Sai balaji (Testing)</option>
                            <option value="Sathish (IT)">Sathish (IT)</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="respectiveDepartment">Respective Department</label>
                    <div class="select-wrapper">
                        <select id="respectiveDepartment" name="RespectiveDepartment">
                            <option value="">Select Department</option>
                            <option value="Production">Production</option>
                            <option value="Quality">Quality</option>
                            <option value="Maintenance">Maintenance</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="appleDri">Apple DRI</label>
                    <div class="select-wrapper">
                        <select id="appleDri" name="AppleDri">
                            <option value="">Select Apple DRI</option>
                            <option value="Selva Kumar">Selva Kumar</option>    
                            
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="typeOfAudit">Type of Audit</label>
                    <div class="select-wrapper">
                        <select id="typeOfAudit" name="TypeOfAudit">
                            <option value="">Select Audit Type</option>
                            <option value="Internal">Internal</option>
                            <option value="Customer">Customer</option>
                        </select>
                        <span class="select-arrow">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                    </div>
                </div>
                <div class="form-group">
                    <label>Before Image</label>

                    <div class="custom-file-box" id="beforeFileBox">
                        <label for="beforeImage" class="choose-file-btn">Choose File</label>

                        <div class="file-display-area" id="beforeFileDisplay">
                            <span class="file-placeholder" id="beforeFileText">No image uploaded</span>
                            <img id="beforePreviewInline"
                                 class="inline-image-preview clickable-preview"
                                 style="display:none;"
                                 alt="Preview"
                                 onclick="openImageModal(this.src)" />
                        </div>

                        <button type="button" class="remove-image-btn" id="beforeRemoveBtn" onclick="removeSelectedImage('before')" style="display:none;">
                            <i class="fa-solid fa-xmark"></i>
                        </button>

                        <button type="button" class="camera-inside-btn" onclick="openCamera('before')">
                            <i class="fa fa-camera"></i>
                        </button>

                        <input type="file"
                               id="beforeImage"
                               name="BeforeImage"
                               accept="image/*"
                               class="hidden-file-input" />
                    </div>

                    <div class="camera-box" id="beforeCameraBox" style="display:none;">
                        <video id="beforeVideo" autoplay playsinline></video>
                        <canvas id="beforeCanvas" style="display:none;"></canvas>

                        <div class="camera-action-row">
                            <button type="button" class="capture-btn" onclick="captureImage('before')">Capture</button>
                            <button type="button" class="close-btn" onclick="closeCamera('before')">Close</button>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="status">Status</label>
                    <input type="text"
                           id="status"
                           name="Status"
                           value=""
                           placeholder="Auto Status"
                           readonly />
                </div>
                @* <div class="form-group"> *@
                @*     <label for="status">Status</label> *@
                @*     <div class="select-wrapper"> *@
                @*         <select id="status" name="Status"> *@
                @*             <option value="">Select Status</option> *@
                @*             <option value="Close">Close</option> *@
                @*             <option value="Drop">Drop</option> *@
                @*             <option value="Ongoing">Ongoing</option> *@
                @*         </select> *@
                @*         <span class="select-arrow"> *@
                @*             <i class="fa fa-chevron-down"></i> *@
                @*         </span> *@
                @*     </div> *@
                @* </div> *@
            </div>

            <div class="button-row">
                <button type="submit" class="save-btn">Submit</button>
            </div>
        </form>

        <hr class="form-divider">
        <div class="table-section">
            <h3 class="table-title">Checklist Records</h3>

            <div class="table-wrapper">
                <table class="checklist-table" id="checklistTable">
                    <thead>
                        <tr>
                            <th>S.NO</th>
                            <th>Section</th>
                            <th>Station Name</th>
                            <th>Issue Type</th>
                            <th>Problem Statement</th>
                            <th>Frequency</th>
                            <th>Issue Severity</th>
                            <th>Category</th>
                            <th>Starting Date</th>
                            <th>Due Date</th>
                            <th>CM DRI</th>
                            <th>Respective Department</th>
                            <th>Apple DRI</th>
                            <th>Type of Audit</th>
                            <th>Before Image</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="checklistTableBody">
                        @if (Model != null && Model.Any())
                        {
                            int serialNo = 1;
                            foreach (var item in Model.Take(6))
                            {
                                <tr>
                                    <td>@serialNo</td>
                                    <td>@item.Section</td>
                                    <td>@item.StationName</td>
                                    <td>@item.IssueType</td>
                                    <td>@item.ProblemStatement</td>
                                    <td>@item.Frequency</td>
                                    <td>@item.IssueSeverity</td>
                                    <td>@item.Category</td>
                                    <td>@(item.Date?.ToString("dd-MM-yyyy"))</td>
                                    <td>@(item.DueDate?.ToString("dd-MM-yyyy"))</td>
                                    <td>@item.CmDri</td>
                                    <td>@item.RespectiveDepartment</td>
                                    <td>@item.AppleDri</td>
                                    <td>@item.TypeOfAudit</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.BeforeImagePath))
                                        {
                                            <img src="@item.BeforeImagePath"
                                                 class="table-preview-img clickable-img"
                                                 alt="Before Image"
                                                 onclick="openImageModal(this.src)" />
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="status-badge
                                            @(item.Status == "Ongoing" ? "status-ongoing" :
                                              item.Status == "Closed" ? "status-closed" :
                                              item.Status == "Drop" ? "status-drop" : "status-default")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                                serialNo++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div id="imageModal" class="image-modal" onclick="handleModalBackgroundClick(event)">
        <span class="close-modal" onclick="closeImageModal()">&times;</span>
        <img class="modal-content" id="modalImage" alt="Large preview" />
    </div>
</div>

<script>
    const cameraStreams = {};

    async function openCamera(type) {
        const cameraBox = document.getElementById(type + "CameraBox");
        const video = document.getElementById(type + "Video");

        try {
            const stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: "environment" },
                audio: false
            });

            cameraStreams[type] = stream;
            video.srcObject = stream;
            cameraBox.style.display = "block";
        } catch (error) {
            alert("Unable to access camera. Please allow camera permission or use Choose File.");
            console.error(error);
        }
    }

        function captureImage(type) {
        const video = document.getElementById(type + "Video");
        const canvas = document.getElementById(type + "Canvas");
        const fileInput = document.getElementById(type + "Image");

        const context = canvas.getContext("2d");
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(function (blob) {
            const file = new File([blob], type + "-capture.jpg", { type: "image/jpeg" });

            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            fileInput.files = dataTransfer.files;

            updateInlineImagePreview(type, file);
            updateStatusAutomatically();

            closeCamera(type);
        }, "image/jpeg");
    }

    function closeCamera(type) {
        const cameraBox = document.getElementById(type + "CameraBox");
        const video = document.getElementById(type + "Video");

        if (cameraStreams[type]) {
            cameraStreams[type].getTracks().forEach(track => track.stop());
            cameraStreams[type] = null;
        }

        video.srcObject = null;
        cameraBox.style.display = "none";
    }

    function updateInlineImagePreview(type, file) {
        const preview = document.getElementById(type + "PreviewInline");
        const text = document.getElementById(type + "FileText");
        const removeBtn = document.getElementById(type + "RemoveBtn");

        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.style.display = "block";
            text.style.display = "none";
            removeBtn.style.display = "flex";
        } else {
            preview.src = "";
            preview.style.display = "none";
            text.textContent = "No image uploaded";
            text.style.display = "inline";
            removeBtn.style.display = "none";
        }

        updateStatusAutomatically();
    }

    function removeSelectedImage(type) {
        const fileInput = document.getElementById(type + "Image");
        const preview = document.getElementById(type + "PreviewInline");
        const text = document.getElementById(type + "FileText");
        const removeBtn = document.getElementById(type + "RemoveBtn");

        fileInput.value = "";
        preview.src = "";
        preview.style.display = "none";
        text.textContent = "No image uploaded";
        text.style.display = "inline";
        removeBtn.style.display = "none";

        updateStatusAutomatically();
    }

    const beforeImageInput = document.getElementById("beforeImage");
    if (beforeImageInput) {
        beforeImageInput.addEventListener("change", function (e) {
            const file = e.target.files[0];
            updateInlineImagePreview("before", file);
        });
    }

    const dateInput = document.getElementById("date");
    const weekCodeInput = document.getElementById("weekCode");
    const monthInput = document.getElementById("month");
    const statusField = document.getElementById("status");
    const checklistForm = document.getElementById("checklistForm");

    if (dateInput) {
        dateInput.addEventListener("change", function () {
            if (!this.value) {
                weekCodeInput.value = "";
                monthInput.value = "";
                updateStatusAutomatically();
                return;
            }

            const selectedDate = new Date(this.value);

            if (isNaN(selectedDate.getTime())) {
                weekCodeInput.value = "";
                monthInput.value = "";
                updateStatusAutomatically();
                return;
            }

            monthInput.value = selectedDate.toLocaleString("en-US", { month: "long" });

            const weekNumber = getISOWeekNumber(selectedDate);
            weekCodeInput.value = "WK-" + String(weekNumber).padStart(2, "0");

            updateStatusAutomatically();
        });
    }

    function getISOWeekNumber(date) {
        const tempDate = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = tempDate.getUTCDay() || 7;

        tempDate.setUTCDate(tempDate.getUTCDate() + 4 - dayNum);

        const yearStart = new Date(Date.UTC(tempDate.getUTCFullYear(), 0, 1));
        return Math.ceil((((tempDate - yearStart) / 86400000) + 1) / 7);
    }

    function startSpeech(fieldId, btnElement) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        if (!SpeechRecognition) {
            alert("Use Chrome browser");
            return;
        }

        if (btnElement) {
            btnElement.classList.add("recording");
        }

        const recognition = new SpeechRecognition();
        recognition.start();

        recognition.onresult = function (event) {
            const text = event.results[0][0].transcript;
            document.getElementById(fieldId).value += " " + text;
            updateStatusAutomatically();
        };

        recognition.onend = function () {
            if (btnElement) {
                btnElement.classList.remove("recording");
            }
        };
    }

        function updateStatusAutomatically() {
        const fields = [
            "date",
            "weekCode",
            "month",
            "project",
            "line",
            "section",
            "stationName",
            "issueType",
            "problemStatement",
            "frequency",
            "issueSeverity",
            "category",
            "dueDate",
            "cmDri",
            "respectiveDepartment",
            "appleDri",
            "typeOfAudit"
        ];

        let allFilled = true;

        fields.forEach(id => {
            const field = document.getElementById(id);

            if (!field || !field.value || field.value.trim() === "") {
                allFilled = false;
            }
        });

        const beforeImage = document.getElementById("beforeImage");

        if (!beforeImage || beforeImage.files.length === 0) {
            allFilled = false;
        }

        const statusField = document.getElementById("status");

        if (statusField) {
            statusField.value = allFilled ? "Ongoing" : "";
        }
    }

        const issueTypeInput = document.getElementById("issueType");
    const frequencyInput = document.getElementById("frequency");

    function handleFrequencyByIssueType() {
        if (!issueTypeInput || !frequencyInput) return;

        if (issueTypeInput.value === "New") {
            frequencyInput.value = "1";
            frequencyInput.disabled = true;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "none";
                wrapper.style.opacity = "0.7";
            }
        }
        else if (issueTypeInput.value === "Repeated") {
            frequencyInput.value = "";
            frequencyInput.disabled = false;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "auto";
                wrapper.style.opacity = "1";
            }
        }
        else {
            frequencyInput.value = "";
            frequencyInput.disabled = false;

            const wrapper = frequencyInput.closest(".select-wrapper");
            if (wrapper) {
                wrapper.style.pointerEvents = "auto";
                wrapper.style.opacity = "1";
            }
        }

        updateStatusAutomatically();
    }

    if (issueTypeInput) {
        issueTypeInput.addEventListener("change", handleFrequencyByIssueType);
    }

    handleFrequencyByIssueType();

    if (checklistForm) {
        const fieldsToWatch = [
            document.getElementById("date"),
            document.getElementById("weekCode"),
            document.getElementById("month"),
            document.getElementById("project"),
            document.getElementById("line"),
            document.getElementById("section"),
            document.getElementById("stationName"),
            document.getElementById("issueType"),
            document.getElementById("problemStatement"),
            document.getElementById("frequency"),
            document.getElementById("issueSeverity"),
            document.getElementById("category"),
            document.getElementById("dueDate"),
            document.getElementById("cmDri"),
            document.getElementById("respectiveDepartment"),
            document.getElementById("appleDri"),
            document.getElementById("typeOfAudit"),
            document.getElementById("beforeImage")
        ];

        fieldsToWatch.forEach(field => {
            if (!field) return;
            field.addEventListener("change", updateStatusAutomatically);
            field.addEventListener("input", updateStatusAutomatically);
        });

        checklistForm.addEventListener("submit", function (e) {
                if (frequencyInput) {
                    frequencyInput.disabled = false;
                }
            const requiredFields = [
                document.getElementById("date"),
                document.getElementById("weekCode"),
                document.getElementById("month"),
                document.getElementById("project"),
                document.getElementById("line"),
                document.getElementById("section"),
                document.getElementById("stationName"),
                document.getElementById("issueType"),
                document.getElementById("problemStatement"),
                document.getElementById("frequency"),
                document.getElementById("issueSeverity"),
                document.getElementById("category"),
                document.getElementById("dueDate"),
                document.getElementById("cmDri"),
                document.getElementById("respectiveDepartment"),
                document.getElementById("appleDri"),
                document.getElementById("typeOfAudit"),
                document.getElementById("beforeImage"),
                document.getElementById("status")
            ];

            let isValid = true;

            requiredFields.forEach(field => {
                if (!field) return;

                if (field.type === "file") {
                    if (field.files.length === 0) {
                        isValid = false;
                    }
                } else {
                    if (!field.value || field.value.trim() === "") {
                        isValid = false;
                    }
                }
            });

            if (!isValid) {
                e.preventDefault();
                showToast("Please provide all the input fields", "linear-gradient(to right, #ff5f6d, #ffc371)");
            }
        });

        updateStatusAutomatically();
    }
</script>
<script>
    function openImageModal(src) {
        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("modalImage");

        modalImg.src = src;
        modal.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function closeImageModal() {
        const modal = document.getElementById("imageModal");

        modal.classList.remove("show");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (!modal.classList.contains("show")) {
                document.getElementById("modalImage").src = "";
            }
        }, 650);
    }

    function handleModalBackgroundClick(event) {
        if (event.target.id === "imageModal") {
            closeImageModal();
        }
    }

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            closeImageModal();
        }
    });
</script>
<script>
    function showToast(message, bgColor) {
        Toastify({
            text: message,
            duration: 3000,
            gravity: "top",
            position: "right",
            close: true,
            stopOnFocus: true,
            style: {
                background: bgColor,
                borderRadius: "10px",
                padding: "12px 18px"
            }
        }).showToast();
    }

</script>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        showToast("@TempData["SuccessMessage"]", "linear-gradient(to right, #00b09b, #96c93d)");
    </script>
}

@if (TempData["ErrorMessage"] != null)
{
    <script>
